# Ad Composition Renderer — Environment Variables

# Port the server listens on (default: 3000)
PORT=3000

# Optional: API key for securing the renderer endpoint.
# Set this and pass it as 'x-api-key' header from n8n.
# Leave blank to disable auth (not recommended in production).
API_KEY=your-secret-key-here

# Optional: Comma-separated list of allowed CORS origins.
# Leave blank to allow all origins.
ALLOWED_ORIGINS=https://your-n8n-instance.com
